<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Verify Code - SpinWinToken</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://unpkg.com/@supabase/supabase-js@2"></script>
</head>
<body>
  <h1>Enter Email Code</h1>

  <p>We sent a 6-digit code to your email.</p>

  <input id="code" type="text" maxlength="6" placeholder="6-digit code" />
  <button id="verifyBtn">Verify & Continue</button>

  <div id="status"></div>

  <script>
    const client = supabase.createClient(
      "https://nloupcyqrgnrcsxcmzqf.supabase.co",
      "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5sb3VwY3lxcmducmNzeGNtenFmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMyNzM0MzYsImV4cCI6MjA5ODg0OTQzNn0.BlhkyZ3Ud6TDK-lXZ_zWG_XkIn1lFmQoUQBNxgtgt-g"
    );

    document.getElementById("verifyBtn").addEventListener("click", async () => {
      const code = document.getElementById("code").value.trim();
      const statusEl = document.getElementById("status");
      const email = localStorage.getItem("pending_email");

      statusEl.textContent = "";

      if (!email) {
        statusEl.textContent = "Missing email context. Go back and sign in again.";
        return;
      }

      if (code.length !== 6) {
        statusEl.textContent = "Enter a valid 6-digit code.";
        return;
      }

      // Verify the email OTP
      const { data, error } = await client.auth.verifyOtp({
        email,
        token: code,
        type: "email"
      });

      if (error) {
        statusEl.textContent = "Invalid or expired code.";
        return;
      }

      statusEl.textContent = "Verified. Signing you in...";
      // At this point, Supabase has created a session
      setTimeout(() => {
        window.location.href = "dashboard.html";
      }, 1000);
    });
  </script>
</body>
</html>
